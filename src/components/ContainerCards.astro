---
import { arraySvgs } from '@/utils/data';
---

<main>
  <main>
    {
      arraySvgs.map(({ url }, i) => (
        <figure>
          <img
            src={url}
            alt={`Logo ${i + 1}`}
            loading={i > 15 ? 'lazy' : 'eager'}
          />
          <figcaption>
            photo by
            <a href='#' target='_blank' rel='noopener noreferrer'>
              Jelle van Leest
            </a>
          </figcaption>
        </figure>
      ))
    }
  </main>
</main>

<style>
  @property --i0 {
    syntax: '<number>';
    initial-value: 0;
    inherits: true;
  }

  @property --o0 {
    syntax: '<number>';
    initial-value: 0;
    inherits: true;
  }
  @property --i1 {
    syntax: '<number>';
    initial-value: 0;
    inherits: false;
  }
  @property --o1 {
    syntax: '<number>';
    initial-value: 0;
    inherits: false;
  }

  main,
  figure {
    display: grid;
  }

  main {
    grid-template-columns: repeat(auto-fit, minmax(17vmax, 1fr));
    min-height: 100vh;
    grid-gap: 0.52vmax;
    padding: 0.52vmax;
    width: 100%;
  }

  figure {
    grid-template: 100%/100%;
    aspect-ratio: 3/2;
    animation: a 1s both;
    animation-name: i, o;
    animation-timeline: view();
    animation-range:
      entry 0% entry 0%,
      exit 100% exit 100%;
    background-color: #fff8;

    &:hover {
      --hov: 1;
    }
  }

  @keyframes i {
    to {
      --i0: 1;
    }
  }
  @keyframes o {
    to {
      --o0: 1;
    }
  }

  figure {
    img,
    figcaption {
      grid-area: 1/1;
    }

    img {
      --i1: var(--i0);
      --o1: var(--o0);
      width: 100%;
      height: 100%;
      object-fit: cover;

      background-color: #fff;
      transition:
        --i1 0.3s ease-out,
        --o1 0.3s ease-in;
      animation: p 1s cubic-bezier(0.32, 0, 0.68, 0) both;
      animation-timeline: view();
      animation-range: entry 0% exit 100%;
      box-shadow: 0.13vmax 0.13vmax 0.33vmax #0007;
    }
  }

  @supports (animation-range: exit 0% exit 0%) {
    figure img {
      scale: calc(var(--i1) - var(--o1));
      opacity: calc(var(--i1) * (1 - var(--o1)));
    }
  }

  @keyframes p {
    0% {
      object-position: 50% 0;
    }
    50% {
      object-position: 50%;
      animation-timing-function: cubic-bezier(0.32, 1, 0.68, 1);
    }
    100% {
      object-position: 50% 100%;
    }
  }

  figcaption {
    place-self: end;
    z-index: 1;
    margin: 0.52vmax;
    padding: 0.52vmax;
    background: #212121ab;
    opacity: 0;
    pointer-events: none;
  }
</style>
